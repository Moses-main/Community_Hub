# =============================================================================
# CLIENT API CONFIGURATION
# =============================================================================

# API Base URL (relative path for same-origin, full URL for separate deployments)
# For local development: /api
# For Vercel/Render: https://your-api-domain.com/api
VITE_API_BASE_URL=/api

# Full API URL (update after deployment to Vercel or Render)
# Example: https://community-hub.onrender.com/api
# For local development, use localhost:3000
VITE_API_URL=http://localhost:3000/api

# WebSocket URL for real-time features (update after deployment)
# Example: wss://community-hub.onrender.com
VITE_WS_URL=ws://localhost:3000

# Set to 'true' for local development
VITE_DEV_MODE=true

# =============================================================================
# AFTER DEPLOYMENT - UPDATE THESE
# =============================================================================
# 1. Deploy to Vercel or Render
# 2. Copy your deployed URL (e.g., https://community-hub.onrender.com)
# 3. Update VITE_API_URL and VITE_WS_URL above with your URL
# 4. Rebuild and redeploy the client
#
# VERCEL: Your app URL will be like: https://your-project.vercel.app
# RENDER: Your app URL will be like: https://your-app.onrender.com
